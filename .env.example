# Public URL used in GitHub Check Run links and the CLI-generated Codex config.
GOVERNOR_URL=http://localhost:3000
# Required in production for signed GitHub webhook verification.
GITHUB_WEBHOOK_SECRET=replace-me
# GitHub App credentials, required only for live Check Runs and PR comments.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=""
# Optional: enables the two-sentence GPT receipt explainer.
OPENAI_API_KEY=
OPENAI_EXPLAINER_MODEL=gpt-5.6
# Optional PostgreSQL database. Without it, Governor starts with a seeded in-memory demo tenant.
DATABASE_URL=
